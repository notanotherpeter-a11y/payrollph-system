{
  "functions": {
    "api/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.css)",
      "headers": { "Content-Type": "text/css" },
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.js)",
      "headers": { "Content-Type": "text/javascript" },
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}